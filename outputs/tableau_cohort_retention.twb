      <aliases enabled='yes' />
      <column caption='Retention 90d %' datatype='real' name='[Calculation_0832610807885828]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='100 * SUM([retained_90d]) / SUM([eligible_for_90d])' />
      </column>
      <column caption='One-and-done %' datatype='real' name='[Calculation_0832610807971845]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='100 * SUM([is_churned]) / COUNT([customer_id])' />
      </column>
      <column caption='Cohort Month No' datatype='integer' name='[Calculation_0832610808033286]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='MONTH([cohort_month])' />
      </column>
      <column caption='Is Holiday Acquisition' datatype='string' name='[Calculation_0832610812571655]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF MONTH([cohort_month]) IN (11, 12) THEN &apos;Holiday&apos; ELSE &apos;Other&apos; END' />
      </column>
